# Configuración del Bot de Telegram - Variables de Entorno
# Copia este archivo como .env y completa con tus datos reales

# Token del bot de Telegram (obténlo de @BotFather)
TELEGRAM_TOKEN=tu_token_de_telegram_aqui

# API Key de OpenWeatherMap (registro gratuito en openweathermap.org)
WEATHER_API_KEY=tu_api_key_de_openweathermap_aqui

# Tu Chat ID de Telegram (obténlo de @userinfobot)
CHAT_ID=tu_chat_id_aqui

# Ciudad para el pronóstico (formato: Ciudad,CodigoPais)
CITY=Madrid,ES

# Hora de envío del mensaje (formato: HH:MM)
TIME_SEND_MESSAGE=07:00

# Zona horaria en la que se encuentra la ciudad
TIMEZONE=Europe/Madrid